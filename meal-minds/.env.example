# Supabase project (Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# USDA FoodData Central (free key at https://fdc.nal.usda.gov/api-key-signup.html)
# DEMO_KEY works for light testing but is heavily rate-limited.
VITE_USDA_API_KEY=DEMO_KEY

# Server-side only — set as a Supabase Edge Function secret, NEVER in the frontend:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
